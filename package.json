{
  "name": "coco",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "bun --filter @coco/convex codegen && turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@pierre/trees": "^1.0.0-beta.3",
    "@types/three": "^0.184.0",
    "three": "^0.184.0"
  }
}

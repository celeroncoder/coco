# Convex client URL — copy from packages/convex/.env.local after `convex dev`.
NEXT_PUBLIC_CONVEX_URL=

# Convex deployment + site URL (optional, used by some server calls/tools).
CONVEX_DEPLOYMENT=
CONVEX_SITE_URL=

# Clerk — from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_LOGO_DEV_TOKEN=

# Custom sign-in/sign-up pages (defaults match the routes shipped in app/)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

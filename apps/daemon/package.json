{
  "name": "@coco/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "coco-agent": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build --compile src/index.ts --outfile dist/coco-agent",
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts start",
    "pair": "bun run src/index.ts pair",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.2"
  }
}
